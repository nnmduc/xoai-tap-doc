# Firebase project config (Firebase Console → Project Settings → Your apps → Web app)
VITE_FIREBASE_API_KEY=AIzaSy...
VITE_FIREBASE_AUTH_DOMAIN=YOUR-PROJECT-ID.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR-PROJECT-ID
VITE_FIREBASE_APP_ID=1:000000000000:web:...

# Firebase Realtime Database URL (Firebase Console → Realtime Database)
VITE_FIREBASE_RTDB_URL=https://YOUR-PROJECT-ID.asia-southeast1.firebasedatabase.app

# Firebase setup checklist:
# 1. Enable Google Sign-In: Authentication → Sign-in method → Google → Enable
# 2. Add your domain to Authorised domains: Authentication → Settings → Authorised domains
# 3. Add RTDB security rules for user data:
#    "users": { "$uid": { ".read": "$uid === auth.uid", ".write": "$uid === auth.uid" } }
